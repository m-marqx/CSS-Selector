{
    "manifest_version": 3,
    "name": "CSS Selector",
    "version": "1.0",
    "icons": {
        "128": "icon.png"
    },
    "description": "Capture and test CSS selectors.",
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "permissions": [
        "activeTab",
        "scripting",
        "tabs"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "popup.html",
                "popup.css",
                "popup.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}